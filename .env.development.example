# Copy this file to .env for local dev.
NODE_ENV=development
PORT=3000

# Public URL of your dev app.
APP_BASE_URL=https://kalender-opa.svcode.dev

# Used to sign the OAuth state parameter.
STATE_SECRET=replace-this-with-a-long-random-string

# Long-lived browser identity cookie settings.
SESSION_COOKIE_NAME=kalender_opa_session
SESSION_COOKIE_MAX_AGE_DAYS=180

# Google OAuth credentials from the kalender-opa-dev GCP project.
GOOGLE_CLIENT_ID=your-dev-web-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-dev-web-oauth-client-secret

# Calendar source mode:
# - selected: calendars that are selected/visible in the user's Google Calendar UI
# - single: exactly one calendar, usually primary
# - explicit: the comma-separated ids in GOOGLE_CALENDAR_IDS
GOOGLE_CALENDAR_SOURCE=selected

# Used when GOOGLE_CALENDAR_SOURCE=single, and also as a fallback value.
GOOGLE_CALENDAR_ID=primary

# Used when GOOGLE_CALENDAR_SOURCE=explicit. Leave empty otherwise.
GOOGLE_CALENDAR_IDS=

# Presentation settings.
DISPLAY_TIME_ZONE=Europe/Amsterdam
DISPLAY_LOCALE=nl-NL
DISPLAY_DAYS_PAST=0
DISPLAY_DAYS_FUTURE=14
MAX_TIMED_EVENTS=40
MAX_ALL_DAY_EVENTS=40

# Sync every 60 seconds.
SYNC_INTERVAL_MS=60000

# Hosts allowed by Vite in development / preview mode.
VITE_ALLOWED_HOSTS=kalender-opa.svcode.dev,localhost,127.0.0.1

# SQLite database location.
DATABASE_PATH=./data/kalender-opa-dev.sqlite
