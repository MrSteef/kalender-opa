# Copy this file to .env on your home server.
NODE_ENV=production
PORT=3000

# Public URL of your production app.
APP_BASE_URL=https://kalender-opa.stefanveltmaat.com

# Used to sign the OAuth state parameter.
STATE_SECRET=replace-this-with-a-long-random-string

# Google OAuth credentials from the kalender-opa GCP project.
GOOGLE_CLIENT_ID=your-prod-web-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-prod-web-oauth-client-secret

# Google Calendar to display. "primary" works for the connected account.
GOOGLE_CALENDAR_ID=primary

# Presentation settings.
DISPLAY_TIME_ZONE=Europe/Amsterdam
DISPLAY_LOCALE=nl-NL
DISPLAY_DAYS_PAST=0
DISPLAY_DAYS_FUTURE=14
MAX_TIMED_EVENTS=40
MAX_ALL_DAY_EVENTS=40

# Sync every 60 seconds.
SYNC_INTERVAL_MS=60000

# In Docker this is persisted through the named volume mounted at /data.
DATABASE_PATH=/data/kalender-opa.sqlite
